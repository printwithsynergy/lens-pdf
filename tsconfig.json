{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true
  },
  "include": ["index.ts", "components", "fallback-pdfjs", "host", "plugin", "types", "units"],
  "exclude": ["node_modules", "dist", "demo", "server", "**/*.test.ts", "**/*.test.tsx"]
}
