{
  "name": "@printwithsynergy/loupe-pdf",
  "version": "0.1.0-beta.2",
  "description": "LoupePDF \u2014 host-agnostic OSS PDF viewer core. Plugin-driven canvas viewer with overlay / panel / toolbar slots.",
  "license": "AGPL-3.0-or-later",
  "author": "Think Neverland LLC",
  "homepage": "https://github.com/Printwithsynergy/loupe-pdf#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Printwithsynergy/loupe-pdf.git"
  },
  "bugs": {
    "url": "https://github.com/Printwithsynergy/loupe-pdf/issues"
  },
  "keywords": [
    "pdf",
    "viewer",
    "react",
    "canvas",
    "annotation",
    "preflight",
    "separations",
    "cmyk",
    "tac",
    "pdfjs"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    },
    "./host": {
      "types": "./dist/host/index.d.ts",
      "import": "./dist/host/index.js"
    },
    "./fallback-pdfjs": {
      "types": "./dist/fallback-pdfjs/index.d.ts",
      "import": "./dist/fallback-pdfjs/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./units": {
      "types": "./dist/units/index.d.ts",
      "import": "./dist/units/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "pdfjs-dist": "^4.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "fabric": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "fabric": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "fabric": "^6.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
