{
  "name": "lens-pdf-server",
  "version": "0.0.0",
  "private": true,
  "description": "Reference HTTP backend for LensPDF — provides ink separations, densitometer, TAC heatmap, color sampling via Ghostscript.",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nunjucks": "^3.2.4",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^22.0.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/nunjucks": "^3.2.6",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
