{
  "name": "@printwithsynergy/lens-server",
  "version": "0.2.0",
  "description": "Canonical headless renderer for the lens-pdf viewer family. Serves report rendering (HTML / PDF / annotated PDF / markup PDF), page rendering, and color sampling for backends that can't run the browser-only lens-pdf React library directly. Powered by Ghostscript + Puppeteer + pdf-lib. Hono + bearer auth + pino logs + Prometheus metrics + RFC 7807 errors.",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/printwithsynergy/lens-pdf.git",
    "directory": "server"
  },
  "homepage": "https://github.com/printwithsynergy/lens-pdf/tree/main/server",
  "bugs": {
    "url": "https://github.com/printwithsynergy/lens-pdf/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lens-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc && node -e \"require('node:fs').cpSync('src/templates','dist/templates',{recursive:true})\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@printwithsynergy/codex-client": "^1.21.0",
    "hono": "^4.6.0",
    "nunjucks": "^3.2.4",
    "pdf-lib": "^1.17.1",
    "pino": "^9.5.0",
    "prom-client": "^15.1.0",
    "puppeteer": "^22.0.0",
    "sharp": "^0.33.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.7.0",
    "@types/nunjucks": "^3.2.6",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "pdf",
    "preflight",
    "printing",
    "prepress",
    "ghostscript",
    "puppeteer",
    "lens-pdf",
    "renderer",
    "hono"
  ]
}
