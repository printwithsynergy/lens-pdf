{
  "name": "@printwithsynergy/lens-server",
  "version": "0.1.0",
  "description": "Canonical headless renderer for the lens-pdf viewer family. Serves report rendering (HTML / PDF / annotated PDF / markup PDF), page rendering, and color sampling for backends that can't run the browser-only lens-pdf React library directly. Powered by Ghostscript + Puppeteer + pdf-lib.",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/printwithsynergy/lens-pdf.git",
    "directory": "server"
  },
  "homepage": "https://github.com/printwithsynergy/lens-pdf/tree/main/server",
  "bugs": {
    "url": "https://github.com/printwithsynergy/lens-pdf/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lens-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc && node -e \"require('node:fs').cpSync('src/templates','dist/templates',{recursive:true})\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "express": "^4.21.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nunjucks": "^3.2.4",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^22.0.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/nunjucks": "^3.2.6",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "pdf",
    "preflight",
    "printing",
    "prepress",
    "ghostscript",
    "puppeteer",
    "lens-pdf",
    "renderer"
  ]
}
